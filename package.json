{
  "name": "unipay-api",
  "version": "1.0.0",
  "description": "UniPay Congo Payment Aggregation API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "postinstall": "npm run build",
    "start": "node dist/app.js",
    "test": "npx tsx --test src/lib/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.51.2",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^8.1.1",
    "@getbrevo/brevo": "^5.0.4",
    "@supabase/supabase-js": "^2.45.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.5",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "@types/pdfkit": "^0.13.9",
    "pdfkit": "^0.15.2",
    "stripe": "^22.2.0",
    "typescript": "^5.4.5",
    "undici": "^5.29.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "pino-pretty": "^11.2.1",
    "solc": "^0.8.20",
    "tsx": "^4.15.7"
  }
}
