PORT=3000
NODE_ENV=development

# Supabase (create project at supabase.com)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# HMAC signing secret (generate: openssl rand -hex 32)
HMAC_SECRET=

# Operator webhook validation secret
OPERATOR_WEBHOOK_SECRET=

# ── Unipesa aggregator (Orange, Airtel, Afrimoney) ─────────
UNIPESA_API_URL=https://api.unipesa.tech
UNIPESA_PUBLIC_ID=
UNIPESA_MERCHANT_ID=
UNIPESA_SECRET_KEY=
UNIPESA_CALLBACK_URL=https://api.unipaycongo.com/v1/payment/callback

# ── Fixie proxy (whitelisted IP for Unipesa) ─────────────────
FIXIE_URL=

# ── Vodacash / M-Pesa — direct integration (coming soon) ─────
# CGL is in due diligence with Vodacom DRC.
VODACASH_API_URL=
VODACASH_API_KEY=

# ── USDT / Crypto (stub) ─────────────────────────────────────
USDT_WALLET_ADDRESS=

# ── Merchant JWT ─────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=

# ── Admin secret (internal KYC tooling) ──────────────────────
# Generate: openssl rand -hex 24
ADMIN_SECRET=

# ── Brevo transactional email ─────────────────────────────────
# Get API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_SENDER_EMAIL=contact@unipaycongo.com
BREVO_SENDER_NAME=UniPay Congo

# ── Dev Expenses Tracker ─────────────────────────────────────
# Anthropic Console API key (for usage cost pull)
ANTHROPIC_ADMIN_API_KEY=
# Vercel team billing API
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
# Public report page origin (Netlify standalone site)
DEV_EXPENSES_PUBLIC_ORIGIN=https://dev-expenses.netlify.app
